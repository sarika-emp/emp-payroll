# =============================================================================
# EmpCloud Unified Deployment — Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# ── Shared Database ──────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=your-strong-password-here

# ── Shared Auth ──────────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-here

# ── MinIO (S3 storage for LMS) ──────────────────────────────────────────────
MINIO_USER=minioadmin
MINIO_PASSWORD=your-minio-password-here

# ── App Source Paths (relative to docker-compose.cloud.yml) ──────────────────
# Adjust these if your repos are in different locations
BILLING_PATH=../../emp-billing/emp-billing
LMS_PATH=../../emp-lms
