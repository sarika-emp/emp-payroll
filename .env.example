# ============================================================================
# EMP-PAYROLL ENVIRONMENT CONFIGURATION
# Copy this to .env and fill in your values
# ============================================================================

NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# ---------------------------------------------------------------------------
# EmpCloud Master Database (users, organizations, auth)
# Shared across all EMP modules. Authentication happens here.
# ---------------------------------------------------------------------------
EMPCLOUD_DB_HOST=localhost
EMPCLOUD_DB_PORT=3306
EMPCLOUD_DB_USER=root
EMPCLOUD_DB_PASSWORD=emp_payroll_secret
EMPCLOUD_DB_NAME=empcloud

# ---------------------------------------------------------------------------
# Payroll Module Database — payroll-specific tables only
# Options: mysql | postgres | mongodb
# ---------------------------------------------------------------------------
DB_PROVIDER=mysql

# SQL (MySQL / PostgreSQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=emp_payroll_secret
DB_NAME=emp_payroll
DB_POOL_MIN=2
DB_POOL_MAX=10

# MongoDB (when DB_PROVIDER=mongodb)
MONGO_URI=mongodb://localhost:27017/emp_payroll

# ---------------------------------------------------------------------------
# Redis (queues, caching, rate limiting)
# ---------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---------------------------------------------------------------------------
# JWT Authentication
# ---------------------------------------------------------------------------
JWT_SECRET=change-this-to-a-64-char-random-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ---------------------------------------------------------------------------
# Email (payslip delivery, notifications)
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=payroll@empcloud.com

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
CORS_ORIGIN=http://localhost:5173

# ---------------------------------------------------------------------------
# Payroll Configuration
# ---------------------------------------------------------------------------
PAYROLL_COUNTRY=IN
PAY_FREQUENCY=monthly
